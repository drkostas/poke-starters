{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "app",
  "cleanUrls": true,
  "rewrites": [{ "source": "/", "destination": "/lab.built.html" }],
  "headers": [
    {
      "source": "/(sprites|maps|fonts|data)/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }]
    }
  ]
}
